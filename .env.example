# Required: branch identifiers for each chain
NOFRILLS_STORE_ID=7952
METRO_STORE_ID=218

# Optional: override the No Frills public API key if it rotates
# NOFRILLS_API_KEY=

# Optional: absolute path to a chromium binary used by the Metro connector.
# When unset, playwright's bundled chromium is used.
# CHROMIUM_PATH=/path/to/chromium

# Optional: set to "false" to launch chromium with a visible window for local
# debugging of the Metro connector. Default is headless.
# HEADLESS=false
